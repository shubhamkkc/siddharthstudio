---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient, urlFor } from "../lib/sanity";
import { homepageQuery } from "../lib/queries";

// Fetch from Sanity (falls back to hardcoded defaults below if null)
let cms: any = null;
try {
  cms = await sanityClient.fetch(homepageQuery);
} catch (e) {
  console.warn("Sanity fetch failed, using hardcoded defaults:", e);
}

// Pricing data
const pricingTiers = [
  {
    name: "Starter",
    price: "₹299",
    originalPrice: "₹999",
    description: "Perfect for individual creators starting out.",
    features: [
      "1 Custom Design",
      "YouTube Thumbnail or Social Post",
      "2 Revisions",
      "WhatsApp Delivery",
      "24hr Turnaround",
    ],
    ctaLabel: "Order Now",
    ctaHref: "https://wa.me/917488316199?text=Hi%2C%20I%20want%20to%20order%20a%20Starter%20design",
    featured: false,
  },
  {
    name: "Standard Pack",
    price: "₹2,449",
    originalPrice: "₹9,990",
    description: "Best for growing channels needing consistent visuals.",
    features: [
      "10 Custom Designs",
      "Mix of Thumbnails & Posts",
      "Unlimited Revisions",
      "Priority Support",
      "48hr Turnaround",
      "Source Files Included",
    ],
    ctaLabel: "Get Access",
    ctaHref: "https://wa.me/917488316199?text=Hi%2C%20I%20want%20the%20Standard%20Pack",
    featured: true,
  },
  {
    name: "Premium Pack",
    price: "₹4,799",
    originalPrice: "₹19,990",
    description: "For professional brands wanting the full package.",
    features: [
      "20 Custom Designs",
      "All Design Categories",
      "Unlimited Revisions",
      "Dedicated Designer",
      "24hr Priority Turnaround",
      "Source Files + Templates",
    ],
    ctaLabel: "Get Access",
    ctaHref: "https://wa.me/917488316199?text=Hi%2C%20I%20want%20the%20Premium%20Pack",
    featured: false,
  },
];

const services = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="m8 21 4-4 4 4"/><path d="M12 17v4"/></svg>`,
    title: "YouTube Thumbnails",
    description: "Scroll-stopping thumbnails that drive clicks. Trend-aware, high-contrast designs crafted for maximum CTR.",
    price: "From ₹299",
    gradient: "grad-a",
    href: "/services#thumbnails",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
    title: "Social Media Designs",
    description: "Posts, banners, stories, and reels covers. Consistent brand identity across every platform.",
    price: "From ₹249",
    gradient: "grad-b",
    href: "/services#social-media",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
    title: "Video Editing",
    description: "Professional video editing for YouTube, Instagram Reels, and brand content. Story-driven cuts.",
    price: "Custom Quote",
    gradient: "grad-c",
    href: "/services#video",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
    title: "Logos & Branding",
    description: "Brand identity packages including logos, color palettes, and style guides for your business.",
    price: "From ₹499",
    gradient: "grad-a",
    href: "/services#branding",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>`,
    title: "Presentations",
    description: "Pitch decks, business presentations, and educational slide decks that impress every audience.",
    price: "From ₹399",
    gradient: "grad-b",
    href: "/services#presentations",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
    title: "Premium Template Packs",
    description: "Ready-to-use template bundles. Edit instantly in Canva or Photoshop. Save time, stay consistent.",
    price: "From ₹999",
    gradient: "grad-c",
    href: "/pricing",
  },
];

const stats = [
  { value: "500+", label: "Designs Delivered" },
  { value: "200+", label: "Happy Creators" },
  { value: "6+", label: "Design Categories" },
  { value: "75%", label: "Savings vs. Market" },
];

const testimonials = [
  {
    name: "Arjun Sharma",
    role: "YouTube Creator · 50K subscribers",
    quote: "My CTR jumped from 3% to 8% after using Siddharth Studious thumbnails. The quality is insane for the price.",
    avatar: "AS",
    rating: 5,
  },
  {
    name: "Priya Verma",
    role: "Digital Marketer · Delhi",
    quote: "Got 20 social media designs in 2 days. Professional, on-brand, and they understood my requirements perfectly.",
    avatar: "PV",
    rating: 5,
  },
  {
    name: "Rohit Kumar",
    role: "Startup Founder · Bangalore",
    quote: "Ordered the Premium Pack for our product launch. The designs were so good our team thought we hired an agency.",
    avatar: "RK",
    rating: 5,
  },
];

const steps = [
  {
    number: "01",
    title: "Choose Your Service",
    description: "Browse our services and select the design you need — thumbnails, social posts, or custom packs.",
  },
  {
    number: "02",
    title: "Share Your Brief",
    description: "Send your requirements via WhatsApp. Include your brand colors, references, and any specific ideas.",
  },
  {
    number: "03",
    title: "Receive Your Design",
    description: "Get your polished design delivered within 24–48 hours. Revisions included until you're happy.",
  },
];

// ── CMS Override: Use Sanity data if available ──
const finalPricingTiers = cms?.pricingTiers ?? pricingTiers;
const finalServices = cms?.services ?? services;
const finalStats = cms?.stats ?? stats;
const finalTestimonials = cms?.testimonials ?? testimonials;
const finalSteps = cms?.steps ?? steps;
const finalFaqItems = cms?.faqItems ?? [
  { question: "What design services does Siddharth Studious offer?", answer: "We specialize in YouTube thumbnails, video editing, social media banner art, Instagram posts/carousels, and premium template design packs tailored for creators and brands." },
  { question: "How do I place an order?", answer: "Simply choose a plan from our pricing page or click any 'Order Now' button to chat with us on WhatsApp. You can share your design brief directly, and we will confirm and start working." },
  { question: "What is the turnaround time for designs?", answer: "Our standard delivery time is 24 to 48 hours depending on the complexity of the design. We prioritize quick deliveries so you never miss an upload schedule." },
  { question: "Do you offer revisions?", answer: "Yes, we offer revisions to ensure you get exactly what you want. Single orders include 2 rounds of revisions, while Standard and Premium design packs include unlimited revisions." },
  { question: "Do I get the source files?", answer: "Yes, raw source files (Figma or Photoshop PSD formats) are fully included with our Standard and Premium design packages." },
];
const heroEyebrow = cms?.heroEyebrow ?? "India's Leading Creative Agency";
// Use CMS headline as plain text, or use styled HTML fallback
const heroHeadlineCms: string | null = cms?.heroHeadline ?? null;
const heroHeadlineFallback = "Designs that make your content <span class=\"gradient-text\">stand out.</span>";
const heroBody = cms?.heroBody ?? "Empowering Creators and Brands with Creative Design, Engaging Video Content and End-to-End Social Media Management.";
const heroFootnote = cms?.heroFootnote ?? "Starting at just ₹249 · Delivered in 24 hours · Revisions included";

// Debug: output hero headline source
console.log('🛠️ heroHeadline value:', heroHeadlineCms ?? heroHeadlineFallback);


const heroPrimaryCtaLabel = cms?.heroPrimaryCta?.label ?? "Order a Design";
const heroPrimaryCtaHref = cms?.heroPrimaryCta?.href ?? "https://wa.me/917488316199?text=Hi%2C%20I%20want%20to%20order%20a%20design";

const heroSecondaryCtaLabel = cms?.heroSecondaryCta?.label ?? "View Our Work";
const heroSecondaryCtaHref = cms?.heroSecondaryCta?.href ?? "/portfolio";

const seoTitle = cms?.seoTitle ?? "Siddharth Studious — India's Premier Creative Design Studio";
const seoDescription = cms?.seoDescription ?? "Professional YouTube thumbnails, social media designs, and premium template packs. Up to 75% off. Trusted by 200+ content creators across India.";
const seoImageUrl = cms?.seoImage ? urlFor(cms.seoImage).url() : undefined;
---

<BaseLayout title={seoTitle} description={seoDescription} image={seoImageUrl}>
    <Navbar />

    <main>
      <!-- ── Announcement Banner ── -->
      <div class="announcement-banner">
        <div class="container-page">
          <a href="/pricing" class="announcement-pill">
            <span class="announcement-badge">🎉 New</span>
            <span class="announcement-text">Premium Pack V2 is here — Up to 75% Off for new clients</span>
            <span class="announcement-arrow">→</span>
          </a>
        </div>
      </div>

      <!-- ── Hero Band ── -->
      <section class="hero-band" id="hero">
        <div class="hero-mesh mesh-gradient"></div>
        <div class="container-page hero-content">
          <p class="hero-eyebrow text-caption-mono animate-fade-up">{heroEyebrow}</p>
          <h1 class="hero-headline animate-fade-up-delay-1" set:html={heroHeadlineCms ?? heroHeadlineFallback} />
          <p class="hero-body animate-fade-up-delay-2">
            {heroBody}
          </p>
          <div class="hero-actions animate-fade-up-delay-3">
            <a
              href={heroPrimaryCtaHref}
              target={heroPrimaryCtaHref.startsWith("http") ? "_blank" : undefined}
              rel={heroPrimaryCtaHref.startsWith("http") ? "noopener noreferrer" : undefined}
              class="hero-btn-primary"
              id="hero-order-cta"
            >
              {heroPrimaryCtaLabel}
            </a>
            <a
              href={heroSecondaryCtaHref}
              target={heroSecondaryCtaHref.startsWith("http") ? "_blank" : undefined}
              rel={heroSecondaryCtaHref.startsWith("http") ? "noopener noreferrer" : undefined}
              class="hero-btn-secondary"
            >
              {heroSecondaryCtaLabel}
            </a>
          </div>
          <p class="hero-footnote animate-fade-up-delay-3">
            {heroFootnote}
          </p>
        </div>
        <!-- Hero Image or Decorative floating cards -->
        {cms?.heroImage ? (
          <div class="hero-image-wrapper animate-fade-up-delay-2">
            <img 
              src={urlFor(cms.heroImage).url()} 
              alt="Hero Illustration" 
              class="hero-image"
            />
          </div>
        ) : (
          <div class="hero-decoration" aria-hidden="true">
            <div class="deco-card deco-card-1 animate-float">
              <div class="deco-dot" style="background:#50e3c2"></div>
              <span>Thumbnail Delivered</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0070f3" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
            </div>
            <div class="deco-card deco-card-2 animate-float" style="animation-delay: 1.5s">
              <div class="deco-dot" style="background:#7928ca"></div>
              <span>CTR: 8.4% ↑</span>
            </div>
            <div class="deco-card deco-card-3 animate-float" style="animation-delay: 0.8s">
              <div class="deco-dot" style="background:#ff0080"></div>
              <span>200+ Creators</span>
            </div>
          </div>
        )}
      </section>

      <!-- ── Stats Strip ── -->
      <section class="stats-strip">
        <div class="container-page">
          <ul class="stats-grid" role="list">
            {finalStats.map(stat => (
              <li class="stat-item">
                <span class="stat-value">{stat.value}</span>
                <span class="stat-label">{stat.label}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- ── Services Grid ── -->
      <section class="section-band" id="services">
        <div class="container-page">
          <div class="section-header">
            <p class="section-eyebrow text-caption-mono">WHAT WE DO</p>
            <h2 class="section-heading">Everything your brand needs.</h2>
            <p class="section-subheading">
              From viral thumbnails to brand identity — we craft visuals that convert.
            </p>
          </div>
          <div class="services-grid">
            {finalServices.map(service => (
              <a href={service.href} class={`service-card service-card-${service.gradient}`} id={`service-${service.title.toLowerCase().replace(/\s+/g, '-')}`}>
                {service.image ? (
                  <div class="service-card-image">
                    <img src={urlFor(service.image).width(600).url()} alt={service.title} />
                  </div>
                ) : (
                  <div class="service-card-icon" set:html={service.icon} />
                )}
                <div class="service-card-content">
                  <h3 class="service-card-title">{service.title}</h3>
                  <p class="service-card-desc">{service.description}</p>
                </div>
                <div class="service-card-footer">
                  <span class="service-price">{service.price}</span>
                  <span class="service-arrow">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- ── How It Works ── -->
      <section class="section-band section-band-soft" id="process">
        <div class="container-page">
          <div class="section-header">
            <p class="section-eyebrow text-caption-mono">THE PROCESS</p>
            <h2 class="section-heading">Ready in 3 simple steps.</h2>
            <p class="section-subheading">No complex onboarding. Just send a message and get your design.</p>
          </div>
          <div class="process-grid">
            {finalSteps.map((step, i) => (
              <div class="process-step">
                <div class="process-number">{step.number}</div>
                {i < finalSteps.length - 1 && <div class="process-connector" aria-hidden="true"></div>}
                {step.image && (
                  <div class="process-image">
                    <img src={urlFor(step.image).width(400).url()} alt={step.title} />
                  </div>
                )}
                <div class="process-content">
                  <h3 class="process-title">{step.title}</h3>
                  <p class="process-desc">{step.description}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="process-cta">
            <a
              href="https://wa.me/917488316199?text=Hi%2C%20I%20want%20to%20order%20a%20design"
              target="_blank"
              rel="noopener noreferrer"
              class="hero-btn-primary"
              id="process-order-cta"
            >
              Start Your Order →
            </a>
          </div>
        </div>
      </section>

      <!-- ── Pricing Section ── -->
      <section class="section-band" id="pricing-preview">
        <div class="container-page">
          <div class="section-header">
            <p class="section-eyebrow text-caption-mono">PRICING</p>
            <h2 class="section-heading">Premium quality. Honest pricing.</h2>
            <p class="section-subheading">No hidden fees. Up to 75% off market rates for new clients.</p>
          </div>
          <div class="pricing-grid">
            {finalPricingTiers.map(tier => (
              <div class={`pricing-card ${tier.featured ? 'pricing-card-featured' : ''}`}>
                {tier.featured && (
                  <div class="pricing-badge">Most Popular</div>
                )}
                <div class="pricing-top">
                  <h3 class="pricing-name">{tier.name}</h3>
                  <p class="pricing-desc">{tier.description}</p>
                </div>
                <div class="pricing-price-block">
                  <span class="pricing-original">{tier.originalPrice}</span>
                  <span class="pricing-price">{tier.price}</span>
                </div>
                <ul class="pricing-features" role="list">
                  {tier.features.map(feat => (
                    <li class="pricing-feature">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                      {feat}
                    </li>
                  ))}
                </ul>
                <a
                  href={tier.ctaHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class={`pricing-cta ${tier.featured ? 'pricing-cta-featured' : ''}`}
                  id={`pricing-${tier.name.toLowerCase().replace(/\s+/g, '-')}-cta`}
                >
                  {tier.ctaLabel}
                </a>
              </div>
            ))}
          </div>
          <p class="pricing-note">
            Need something custom? <a href="https://wa.me/917488316199" target="_blank" rel="noopener noreferrer">Chat with us on WhatsApp →</a>
          </p>
        </div>
      </section>

      <!-- ── Testimonials ── -->
      <section class="section-band section-band-soft" id="testimonials">
        <div class="container-page">
          <div class="section-header">
            <p class="section-eyebrow text-caption-mono">TESTIMONIALS</p>
            <h2 class="section-heading">Creators love our work.</h2>
            <p class="section-subheading">Real feedback from real clients who grew their channels with us.</p>
          </div>
          <div class="testimonials-marquee-container">
            <div class="testimonials-marquee-mask" aria-hidden="true"></div>
            <div class="testimonials-marquee-track">
              <div class="testimonials-marquee-group">
                {finalTestimonials.map(t => (
                  <div class="testimonial-card">
                    <div class="testimonial-stars" aria-label={`${t.rating} out of 5 stars`}>
                      {Array.from({ length: t.rating }, () => '★').join('')}
                    </div>
                    <blockquote class="testimonial-quote">"{t.quote}"</blockquote>
                    <div class="testimonial-author">
                      {t.avatarImage ? (
                        <img class="testimonial-avatar testimonial-avatar-img" src={urlFor(t.avatarImage).width(100).url()} alt={t.name} />
                      ) : (
                        <div class="testimonial-avatar">{t.avatar}</div>
                      )}
                      <div>
                        <p class="testimonial-name">{t.name}</p>
                        <p class="testimonial-role">{t.role}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <!-- Duplicate group for seamless looping -->
              <div class="testimonials-marquee-group" aria-hidden="true">
                {finalTestimonials.map(t => (
                  <div class="testimonial-card">
                    <div class="testimonial-stars" aria-label={`${t.rating} out of 5 stars`}>
                      {Array.from({ length: t.rating }, () => '★').join('')}
                    </div>
                    <blockquote class="testimonial-quote">"{t.quote}"</blockquote>
                    <div class="testimonial-author">
                      {t.avatarImage ? (
                        <img class="testimonial-avatar testimonial-avatar-img" src={urlFor(t.avatarImage).width(100).url()} alt={t.name} />
                      ) : (
                        <div class="testimonial-avatar">{t.avatar}</div>
                      )}
                      <div>
                        <p class="testimonial-name">{t.name}</p>
                        <p class="testimonial-role">{t.role}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── Partner CTA Dark Band ── -->
      <section class="partner-band" id="partner">
        <div class="partner-mesh mesh-gradient"></div>
        <div class="container-page partner-content">
          <p class="partner-eyebrow text-caption-mono">JOIN OUR NETWORK</p>
          <h2 class="partner-heading">Are you a designer or editor?</h2>
          <p class="partner-body">
            Join our growing network of 500+ creators and earn by doing what you love.
            Flexible hours, consistent projects, and a community that grows together.
          </p>
          <div class="partner-actions">
            <a href="/become-a-partner" class="partner-btn-primary" id="partner-apply-cta">Apply as Partner →</a>
            <a href="/about" class="partner-btn-secondary">Learn More</a>
          </div>
        </div>
      </section>
      <!-- ── FAQ Section ── -->
      <section class="section-band" id="faq" style="border-top: 1px solid var(--color-hairline);">
        <div class="container-page" style="max-width: 800px;">
          <h2 class="section-heading faq-title">Frequently Asked Questions</h2>
          <div class="faq-accordion-container">
            {finalFaqItems.map(faq => (
              <details class="faq-details">
                <summary class="faq-summary">
                  <span>{faq.question}</span>
                  <svg class="faq-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </summary>
                <div class="faq-content">
                  <p>{faq.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>

        <script type="application/ld+json" is:inline>
          {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
              {
                "@type": "Question",
                "name": "What design services does Siddharth Studious offer?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "<p>We specialize in YouTube thumbnails, video editing, social media banner art, Instagram posts/carousels, and premium template design packs tailored for creators and brands.</p>"
                }
              },
              {
                "@type": "Question",
                "name": "How do I place an order?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "<p>Simply choose a plan from our pricing page or click any 'Order Now' button to chat with us on WhatsApp. You can share your design brief directly, and we will confirm and start working.</p>"
                }
              },
              {
                "@type": "Question",
                "name": "What is the turnaround time for designs?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "<p>Our standard delivery time is 24 to 48 hours depending on the complexity of the design. We prioritize quick deliveries so you never miss an upload schedule.</p>"
                }
              },
              {
                "@type": "Question",
                "name": "Do you offer revisions?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "<p>Yes, we offer revisions to ensure you get exactly what you want. Single orders include 2 rounds of revisions, while Standard and Premium design packs include unlimited revisions.</p>"
                }
              },
              {
                "@type": "Question",
                "name": "Do I get the source files?",
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": "<p>Yes, raw source files (Figma or Photoshop PSD formats) are fully included with our Standard and Premium design packages.</p>"
                }
              }
            ]
          }
        </script>
      </section>

      <!-- ── SEO Content Section ── -->
      <section class="seo-section">
        <div class="container-page seo-inner">
          <h2>Siddharth Studious: India's Premier Creative Design Studio for Content Creators & Brands</h2>
          <div class="seo-content">
