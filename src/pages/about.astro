---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { sanityClient } from "../lib/sanity";
import { aboutPageQuery, siteConfigQuery } from "../lib/queries";
import { buildWhatsAppHref, getWhatsAppBaseHref } from "../lib/contact";

let cms: any = null;
let siteSettings: any = null;
try {
  cms = await sanityClient.fetch(aboutPageQuery);
} catch (e) {
  console.warn("Sanity fetch failed:", e);
}

try {
  siteSettings = await sanityClient.fetch(siteConfigQuery);
} catch (e) {
  console.warn("Sanity site settings fetch failed:", e);
}

const orderWhatsAppHref = buildWhatsAppHref(getWhatsAppBaseHref(siteSettings), "Hi, I want to order a design");

const seoTitle = cms?.seoTitle ?? "About — GrowSquadz";
const seoDescription = cms?.seoDescription ?? "Learn about GrowSquadz — India's premier creative design studio founded by Kumar Siddharth in Patna, Bihar.";
const heroHeading = cms?.heroHeading ?? "Built by creators,<br />for creators.";
const heroSubheading = cms?.heroSubheading ?? "GrowSquadz was founded with a simple mission: make world-class design accessible to every content creator in India.";

const finalStoryParagraphs = cms?.storyParagraphs ?? [
  "GrowSquadz was founded by Kumar Siddharth in Patna, Bihar. What started as helping fellow creators with YouTube thumbnails quickly grew into a full-fledged creative design studio serving hundreds of creators and businesses across India.",
  "Today, we operate as <strong>GrowSquadz Ventures Private Limited</strong>, with a team of talented designers and a growing partner network. Our designs have helped creators grow their channels, improve their CTR, and build recognizable brand identities.",
  "We believe that premium design shouldn't cost a premium. That's why we offer professional-grade work at introductory prices — because every creator deserves to look their best."
];

const defaultProfiles = [
  {
    avatar: "GS",
    name: "GrowSquadz",
    title: "Creative Design Studio",
    bio: "India's premier creative design studio offering YouTube thumbnails, video editing, and social media designs.",
    links: [
      { label: "YouTube", href: "https://youtube.com/@growsquadz" },
      { label: "Instagram", href: "https://www.instagram.com/growsquadz.in/" }
    ]
  },
  {
    avatar: "KS",
    name: "Kumar Siddharth",
    title: "Founder & Director",
    bio: "Passionate designer and content creator helping fellow creators build scroll-stopping visual identities and maximize their channel potential.",
    links: [
      { label: "YouTube", href: "https://youtube.com/@kumarsiddharth" },
      { label: "Instagram", href: "https://instagram.com/kumarsiddharth" }
    ]
  }
];

const finalProfiles = (cms?.profiles && cms.profiles.length > 0) ? cms.profiles : defaultProfiles;

const finalValues = cms?.values ?? [
  { title: "Quality First", icon: "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polygon points=\"12 2 15 8 22 9 17 14 18 21 12 18 6 21 7 14 2 9 9 8\"/></svg>", description: "Every design is crafted with attention to detail. We don't release work we're not proud of." },
  { title: "Accessible Pricing", icon: "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 1v22\"/><path d=\"M5 12h14\"/></svg>", description: "Premium design for everyone — not just big brands with big budgets." },
  { title: "Creator Community", icon: "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg>", description: "We're built by creators for creators. We understand your journey because we've lived it." },
  { title: "Fast Delivery", icon: "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/><polyline points=\"17 8 12 3 7 8\"/><line x1=\"12\" y1=\"3\" x2=\"12\" y2=\"15\"/></svg>", description: "Time is money for content creators. We deliver within 24–48 hours, always." }
];


---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="GrowSquadz" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Navbar />
    <main>
      <!-- Hero -->
      <section class="about-hero">
        <div class="about-hero-mesh mesh-gradient" aria-hidden="true"></div>
        <div class="container-page about-hero-content">
          <p class="section-eyebrow text-caption-mono">ABOUT US</p>
          <h1 class="about-heading" set:html={heroHeading} />
          <p class="about-subheading">{heroSubheading}</p>
        </div>
      </section>

      <!-- Story -->
      <section class="story-section">
        <div class="container-page story-grid">
          <div class="story-text">
            <p class="section-eyebrow text-caption-mono">OUR STORY</p>
            <h2 class="story-heading">Started with a thumbnail. Grew into a studio.</h2>
            {finalStoryParagraphs.map((para: string) => (
              <p set:html={para} />
            ))}
          </div>
          <div class="story-card">
            {finalProfiles.map((profile: any) => (
              <div class="founder-card">
                <div class="founder-avatar">{profile.avatar ?? "GS"}</div>
                <div class="founder-info">
                  <h3 class="founder-name">{profile.name ?? "GrowSquadz"}</h3>
                  <p class="founder-title">{profile.title ?? "Creative Design Studio"}</p>
                  <p class="founder-bio">
                    {profile.bio ?? ""}
                  </p>
                </div>
                <div class="founder-links">
                  {(profile.links ?? []).map((link: any) => (
                    <a href={link.href} target="_blank" rel="noopener noreferrer" class="founder-link">
                      {link.label} →
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Values -->
      <section class="values-section">
        <div class="container-page">
          <div class="section-header">
            <p class="section-eyebrow text-caption-mono">OUR VALUES</p>
            <h2 class="section-heading">What we stand for.</h2>
          </div>
          <div class="values-grid">
            {finalValues.map((val: any) => (
              <div class="value-card">
                <div class="value-icon" set:html={val.icon}></div>
                <h3 class="value-title">{val.title}</h3>
                <p class="value-desc">{val.desc || val.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>


    </main>
    <Footer />
  </body>
</html>

<style>
  .about-hero {
    background: var(--color-canvas);
    position: relative;
    overflow: hidden;
    padding: 80px 24px 72px;
    border-bottom: 1px solid var(--color-hairline);
  }
  .about-hero-mesh { position: absolute; inset: 0; opacity: 0.5; pointer-events: none; }
  .about-hero-content { position: relative; z-index: 1; }
  .section-eyebrow { color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 12px; }
  .about-heading { font-size: clamp(36px, 5vw, 56px); font-weight: 600; letter-spacing: -2px; color: var(--color-ink); margin: 0 0 20px; line-height: 1.05; }
  .about-subheading { font-size: 18px; color: var(--color-body); line-height: 28px; max-width: 560px; margin: 0; }

  .story-section { padding: 80px 24px; background: var(--color-canvas-soft); }
  .story-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .story-text {}
  .story-heading { font-size: 28px; font-weight: 600; letter-spacing: -1px; color: var(--color-ink); margin: 12px 0 20px; line-height: 1.2; }
  .story-text p { font-size: 16px; color: var(--color-body); line-height: 26px; margin: 0 0 16px; }
  .story-text p:last-child { margin-bottom: 0; }
  .story-text strong { color: var(--color-ink); font-weight: 600; }

  .founder-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-card);
    margin-bottom: 16px;
  }
  .founder-avatar {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, #007cf0, #7928ca);
    color: white;
    font-size: 22px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .founder-name { font-size: 18px; font-weight: 600; color: var(--color-ink); margin: 0 0 4px; }
  .founder-title { font-size: 13px; color: var(--color-mute); margin: 0 0 12px; font-family: var(--font-mono); }
  .founder-bio { font-size: 14px; color: var(--color-body); line-height: 20px; margin: 0 0 20px; }
  .founder-links { display: flex; gap: 12px; }
  .founder-link { font-size: 13px; color: var(--color-link); text-decoration: none; font-weight: 500; }
  .founder-link:hover { text-decoration: underline; }

  .company-info-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 24px;
    box-shadow: var(--shadow-card);
  }
  .company-info-card h4 { font-size: 13px; font-weight: 600; color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 16px; font-family: var(--font-mono); }
  dl { margin: 0; }
  .info-row { display: flex; justify-content: space-between; gap: 16px; padding: 8px 0; border-bottom: 1px solid var(--color-hairline); }
  .info-row:last-child { border-bottom: none; }
  dt { font-size: 13px; color: var(--color-mute); flex-shrink: 0; }
  dd { font-size: 13px; color: var(--color-ink); font-weight: 500; margin: 0; text-align: right; }

  .values-section { padding: 80px 24px; background: var(--color-canvas); border-top: 1px solid var(--color-hairline); }
  .section-header { text-align: center; margin-bottom: 48px; }
  .section-heading { font-size: clamp(24px, 3vw, 32px); font-weight: 600; letter-spacing: -1.28px; color: var(--color-ink); margin: 0; }
  .values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .value-card {
    background: var(--color-canvas-soft);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-card);
  }
  .value-icon { font-size: 32px; margin-bottom: 16px; }
  .value-title { font-size: 16px; font-weight: 600; color: var(--color-ink); margin: 0 0 8px; }
  .value-desc { font-size: 14px; color: var(--color-body); line-height: 20px; margin: 0; }


  .hero-btn-primary {
    display: inline-flex; align-items: center; height: 48px; padding: 0 24px;
    font-size: 16px; font-weight: 500; color: var(--color-on-primary); background: var(--color-ink);
    border-radius: var(--radius-pill); text-decoration: none; transition: opacity 0.15s;
  }
  .hero-btn-primary:hover { opacity: 0.85; }

  @media (max-width: 900px) {
    .story-grid { grid-template-columns: 1fr; gap: 40px; }
    .values-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .values-grid { grid-template-columns: 1fr; }
  }
</style>
