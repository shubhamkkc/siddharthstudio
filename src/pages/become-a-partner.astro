---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Become a Partner — Siddharth Studious</title>
    <meta name="description" content="Join the Siddharth Studious partner network. Earn by designing and creating for 200+ clients. Flexible work, consistent projects, great community." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Navbar />
    <main>
      <!-- Hero -->
      <section class="partner-hero">
        <div class="partner-hero-mesh mesh-gradient" aria-hidden="true"></div>
        <div class="container-page partner-hero-content">
          <div class="partner-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Join 500+ Partners
          </div>
          <h1 class="partner-heading">Turn your skills into<br />a steady income.</h1>
          <p class="partner-subheading">
            Are you a graphic designer, video editor, or content creator?
            Join our partner network and earn consistently doing what you love.
          </p>
          <a href="#apply" class="hero-btn-primary" id="partner-hero-apply">Apply Now →</a>
        </div>
      </section>

      <!-- Benefits -->
      <section class="benefits-section">
        <div class="container-page">
          <div class="section-header">
            <p class="section-eyebrow text-caption-mono">PARTNER BENEFITS</p>
            <h2 class="section-heading">Why join Siddharth Studious?</h2>
          </div>
          <div class="benefits-grid">
            {[
              { icon: "💰", title: "Competitive Pay", desc: "Earn market-rate commissions for every project completed. Fast payments via UPI." },
              { icon: "📅", title: "Flexible Schedule", desc: "Work on your own time. Set your own availability and take projects that fit your schedule." },
              { icon: "🚀", title: "Consistent Work", desc: "With 200+ active clients, there's always a steady stream of projects waiting for partners." },
              { icon: "🎓", title: "Skill Growth", desc: "Learn from senior designers, access premium tools, and grow your portfolio with real client work." },
              { icon: "🤝", title: "Supportive Community", desc: "Join a network of creators. Collaborate, share tips, and grow together in our partner chat." },
              { icon: "⭐", title: "Build Your Reputation", desc: "Get client reviews, build a portfolio, and establish yourself as a trusted designer." },
            ].map(b => (
              <div class="benefit-card">
                <div class="benefit-icon">{b.icon}</div>
                <h3 class="benefit-title">{b.title}</h3>
                <p class="benefit-desc">{b.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Who Can Apply -->
      <section class="eligibility-section">
        <div class="container-page eligibility-grid">
          <div>
            <p class="section-eyebrow text-caption-mono">WHO CAN APPLY</p>
            <h2 class="eligibility-heading">We're looking for talented creators.</h2>
            <p class="eligibility-desc">
              If you have the skills and the drive, we have the projects. No minimum experience required —
              we value quality and dedication above all else.
            </p>
            <div class="role-tags">
              {["Graphic Designers", "Video Editors", "Thumbnail Artists", "Social Media Designers", "Motion Graphic Artists", "Content Creators"].map(role => (
                <span class="role-tag">{role}</span>
              ))}
            </div>
          </div>
          <div class="process-steps">
            <h3 class="process-steps-heading text-caption-mono">HOW TO JOIN</h3>
            {[
              { step: "01", title: "Fill the Application", desc: "Submit the form below with your portfolio samples and skills." },
              { step: "02", title: "Portfolio Review", desc: "Our team reviews your work within 48 hours and reaches out." },
              { step: "03", title: "Onboarding Call", desc: "Quick call to align on expectations, pricing, and project types." },
              { step: "04", title: "Start Earning", desc: "Get your first project assignment and start growing with us." },
            ].map(s => (
              <div class="process-step-item">
                <div class="ps-number">{s.step}</div>
                <div>
                  <div class="ps-title">{s.title}</div>
                  <div class="ps-desc">{s.desc}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Application Form -->
      <section class="apply-section" id="apply">
        <div class="container-page apply-inner">
          <div class="section-header">
            <p class="section-eyebrow text-caption-mono">APPLY NOW</p>
            <h2 class="section-heading">Start your application.</h2>
            <p class="section-subheading">Takes less than 2 minutes. We'll get back to you within 48 hours.</p>
          </div>
          <form class="apply-form" action="https://wa.me/917488316199" id="partner-application-form">
            <div class="form-row">
              <div class="form-group">
                <label for="partner-name" class="form-label">Full Name</label>
                <input type="text" id="partner-name" name="name" class="form-input" placeholder="Your name" required />
              </div>
              <div class="form-group">
                <label for="partner-phone" class="form-label">Phone / WhatsApp</label>
                <input type="tel" id="partner-phone" name="phone" class="form-input" placeholder="+91 98765 43210" required />
              </div>
            </div>
            <div class="form-group">
              <label for="partner-email" class="form-label">Email Address</label>
              <input type="email" id="partner-email" name="email" class="form-input" placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label for="partner-role" class="form-label">I am a…</label>
              <select id="partner-role" name="role" class="form-input">
                <option value="">Select your role</option>
                <option>Graphic Designer</option>
                <option>Video Editor</option>
                <option>Thumbnail Artist</option>
                <option>Social Media Designer</option>
                <option>Motion Graphics Artist</option>
                <option>Content Creator</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="partner-portfolio" class="form-label">Portfolio Link</label>
              <input type="url" id="partner-portfolio" name="portfolio" class="form-input" placeholder="https://behance.net/yourprofile" />
            </div>
            <div class="form-group">
              <label for="partner-message" class="form-label">Tell us about yourself</label>
              <textarea id="partner-message" name="message" class="form-textarea" rows="4" placeholder="Briefly describe your experience and why you'd like to join..."></textarea>
            </div>
            <div class="form-submit-row">
              <button type="submit" class="form-submit-btn" id="partner-form-submit">Submit Application →</button>
              <p class="form-note">Or apply directly on <a href="https://wa.me/917488316199?text=Hi%2C%20I%20want%20to%20become%20a%20partner" target="_blank" rel="noopener noreferrer">WhatsApp</a></p>
            </div>
          </form>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<script>
  // Redirect to WhatsApp with form data
  document.getElementById('partner-application-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const name = (form.querySelector('#partner-name') as HTMLInputElement).value;
    const phone = (form.querySelector('#partner-phone') as HTMLInputElement).value;
    const role = (form.querySelector('#partner-role') as HTMLSelectElement).value;
    const portfolio = (form.querySelector('#partner-portfolio') as HTMLInputElement).value;
    const message = (form.querySelector('#partner-message') as HTMLTextAreaElement).value;

    const text = `Hi, I want to apply as a Partner!\n\nName: ${name}\nPhone: ${phone}\nRole: ${role}\nPortfolio: ${portfolio}\n\n${message}`;
    window.open(`https://wa.me/917488316199?text=${encodeURIComponent(text)}`, '_blank');
  });
</script>

<style>
  .partner-hero {
    background: var(--color-ink);
    position: relative;
    overflow: hidden;
    padding: 96px 24px 80px;
    color: white;
  }
  .partner-hero-mesh { position: absolute; inset: 0; opacity: 0.15; pointer-events: none; }
  .partner-hero-content { position: relative; z-index: 1; max-width: 680px; }
  .partner-badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15);
    color: #ccc; font-size: 13px; font-weight: 500;
    padding: 6px 14px; border-radius: var(--radius-full);
    margin-bottom: 24px;
  }
  .partner-heading { font-size: clamp(36px, 5vw, 56px); font-weight: 600; letter-spacing: -2px; color: white; margin: 0 0 20px; line-height: 1.05; }
  .partner-subheading { font-size: 18px; color: #a1a1a1; line-height: 28px; margin: 0 0 32px; max-width: 480px; }
  .hero-btn-primary {
    display: inline-flex; align-items: center; height: 48px; padding: 0 24px;
    font-size: 16px; font-weight: 500; color: var(--color-ink); background: white;
    border-radius: var(--radius-pill); text-decoration: none; transition: opacity 0.15s;
  }
  .hero-btn-primary:hover { opacity: 0.9; }

  .benefits-section { padding: 80px 24px; background: var(--color-canvas-soft); }
  .section-header { text-align: center; margin-bottom: 48px; }
  .section-eyebrow { color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 12px; }
  .section-heading { font-size: clamp(24px, 3vw, 36px); font-weight: 600; letter-spacing: -1.28px; color: var(--color-ink); margin: 0 0 12px; }
  .section-subheading { font-size: 17px; color: var(--color-body); line-height: 26px; margin: 0 auto; max-width: 480px; }
  .benefits-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .benefit-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 28px;
    box-shadow: var(--shadow-card);
  }
  .benefit-icon { font-size: 28px; margin-bottom: 16px; }
  .benefit-title { font-size: 16px; font-weight: 600; color: var(--color-ink); margin: 0 0 8px; }
  .benefit-desc { font-size: 14px; color: var(--color-body); line-height: 20px; margin: 0; }

  .eligibility-section { padding: 80px 24px; background: var(--color-canvas); border-top: 1px solid var(--color-hairline); }
  .eligibility-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
  .eligibility-heading { font-size: 28px; font-weight: 600; letter-spacing: -1px; color: var(--color-ink); margin: 12px 0 16px; line-height: 1.2; }
  .eligibility-desc { font-size: 16px; color: var(--color-body); line-height: 26px; margin: 0 0 24px; }
  .role-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .role-tag {
    font-size: 13px; font-weight: 500; color: var(--color-body);
    background: var(--color-canvas-soft-2); border: 1px solid var(--color-hairline);
    padding: 6px 14px; border-radius: var(--radius-full);
  }
  .process-steps-heading { color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 20px; display: block; }
  .process-steps { display: flex; flex-direction: column; gap: 0; }
  .process-step-item { display: flex; gap: 20px; align-items: flex-start; padding: 20px 0; border-bottom: 1px solid var(--color-hairline); }
  .process-step-item:last-child { border-bottom: none; }
  .ps-number { font-size: 16px; font-weight: 700; color: var(--color-hairline-strong); font-family: var(--font-mono); flex-shrink: 0; line-height: 1; margin-top: 2px; }
  .ps-title { font-size: 15px; font-weight: 600; color: var(--color-ink); margin-bottom: 4px; }
  .ps-desc { font-size: 14px; color: var(--color-body); line-height: 20px; }

  .apply-section { padding: 80px 24px; background: var(--color-canvas-soft); border-top: 1px solid var(--color-hairline); }
  .apply-inner { max-width: 640px; margin: 0 auto; }
  .apply-form { display: flex; flex-direction: column; gap: 20px; margin-top: 0; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 14px; font-weight: 500; color: var(--color-ink); }
  .form-input, .form-textarea {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-sm);
    padding: 0 12px;
    height: 40px;
    font-size: 14px;
    font-family: var(--font-sans);
    color: var(--color-ink);
    outline: none;
    transition: border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }
  .form-input:focus, .form-textarea:focus { border-color: var(--color-ink); }
  .form-textarea { height: auto; padding: 12px; resize: vertical; }
  .form-submit-row { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; margin-top: 8px; }
  .form-submit-btn {
    display: inline-flex; align-items: center; height: 48px; padding: 0 28px;
    font-size: 16px; font-weight: 500; color: white; background: var(--color-ink);
    border: none; border-radius: var(--radius-pill); cursor: pointer; transition: opacity 0.15s;
    font-family: var(--font-sans);
  }
  .form-submit-btn:hover { opacity: 0.85; }
  .form-note { font-size: 14px; color: var(--color-mute); margin: 0; }
  .form-note a { color: var(--color-link); text-decoration: none; font-weight: 500; }
  .form-note a:hover { text-decoration: underline; }

  @media (max-width: 900px) {
    .benefits-grid { grid-template-columns: repeat(2, 1fr); }
    .eligibility-grid { grid-template-columns: 1fr; gap: 40px; }
  }
  @media (max-width: 640px) {
    .benefits-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
