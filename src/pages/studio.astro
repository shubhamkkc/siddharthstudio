---
/**
 * Sanity Studio — Embedded in Astro
 * Access at /studio in your browser
 */
export const prerender = true;

import SanityStudio from "../components/SanityStudio";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GrowSquadz — Content Studio</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="GrowSquadz" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body style="margin: 0; padding: 0;">
    <SanityStudio client:only="react" />
  </body>
</html>
