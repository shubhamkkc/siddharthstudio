---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { sanityClient, urlFor } from "../lib/sanity";
import { portfolioPageQuery } from "../lib/queries";

let cmsPage: any = null;
try {
  cmsPage = await sanityClient.fetch(portfolioPageQuery);
} catch (e) {
  console.warn("Sanity fetch failed:", e);
}

const seoTitle = cmsPage?.seoTitle ?? "Portfolio — Siddharth Studious";
const seoDescription = cmsPage?.seoDescription ?? "Browse our portfolio of professional YouTube thumbnails, social media designs, logos, and brand identity work.";
const heroHeading = cmsPage?.heroHeading ?? "Our recent work.";
const heroSubheading = cmsPage?.heroSubheading ?? "A selection of designs created for our clients. Every pixel is intentional.";

const ctaHeading = cmsPage?.ctaHeading ?? "Want a design like this?";
const ctaBody = cmsPage?.ctaBody ?? "Order yours today and get it delivered within 24 hours.";

const portfolioItems = [
  { id: "p1", category: "thumbnail", title: "Gaming Channel Thumbnail", client: "Tech Creator", color: "#007cf0" },
  { id: "p2", category: "social", title: "Instagram Post Design", client: "Lifestyle Brand", color: "#7928ca" },
  { id: "p3", category: "thumbnail", title: "Finance YouTube Thumbnail", client: "Finance Creator", color: "#ff4d4d" },
  { id: "p4", category: "branding", title: "Startup Logo Design", client: "EdTech Startup", color: "#00dfd8" },
  { id: "p5", category: "social", title: "Social Media Banner", client: "Fashion Brand", color: "#ff0080" },
  { id: "p6", category: "thumbnail", title: "Motivation Channel Art", client: "Motivational Creator", color: "#f9cb28" },
  { id: "p7", category: "thumbnail", title: "Cooking Show Thumbnail", client: "Food Creator", color: "#50e3c2" },
  { id: "p8", category: "social", title: "Product Launch Post", client: "D2C Brand", color: "#7928ca" },
  { id: "p9", category: "branding", title: "Creator Brand Kit", client: "Travel Creator", color: "#007cf0" },
  { id: "v1", category: "video", title: "Lo-Fi Beats Video Edit", client: "Siddharth Music", color: "#ff0080", youtubeUrl: "https://www.youtube.com/watch?v=dQw4w9WgXcQ" },
  { id: "v2", category: "video", title: "Tech Unboxing Video Edit", client: "Tech Channel", color: "#00dfd8", youtubeUrl: "https://www.youtube.com/watch?v=dQw4w9WgXcQ" }
];

function getYouTubeEmbedUrl(url: string) {
  if (!url) return "";
  let videoId = "";
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  if (match && match[2].length === 11) {
    videoId = match[2];
  }
  return videoId ? `https://www.youtube.com/embed/${videoId}` : "";
}

const finalPortfolioItems = (cmsPage?.portfolioItems && cmsPage.portfolioItems.length > 0) ? cmsPage.portfolioItems : portfolioItems;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Navbar />
    <main>
      <!-- Hero -->
      <div class="portfolio-hero">
        <div class="container-page">
          <p class="eyebrow text-caption-mono">PORTFOLIO</p>
          <h1 class="portfolio-heading">{heroHeading}</h1>
          <p class="portfolio-subheading">{heroSubheading}</p>
        </div>
      </div>

      <!-- Infinite Moving Thumbnail Marquee Showcase -->
      <section class="marquee-showcase">
        <div class="marquee-container">
          <div class="marquee-mask" aria-hidden="true"></div>
          
          <!-- Track 1: Move Left -->
          <div class="marquee-track">
            <div class="marquee-group marquee-left">
              {finalPortfolioItems.map((item: any) => {
                const itemColor = item.bgColor || item.color || '#007cf0';
                return (
                  <div class="marquee-card" id={`marquee-l-${item.id || item._id}`} title={`Click to view ${item.title}`}>
                    <div class="portfolio-preview" style={`background: linear-gradient(135deg, ${itemColor}20 0%, ${itemColor}40 100%); border-bottom: 3px solid ${itemColor}`}>
                      {item.image ? (
                        <img src={urlFor(item.image).url()} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : item.imageUrl ? (
                        <img src={item.imageUrl} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : (
                        <div class="preview-inner">
                          <div class="preview-label text-caption-mono">{item.category.toUpperCase()}</div>
                          <div class="preview-lines">
                            <div class="preview-line preview-line-wide" style={`background: ${item.lineColor || itemColor}60`}></div>
                            <div class="preview-line preview-line-med" style={`background: ${item.lineColor || itemColor}40`}></div>
                            <div class="preview-line preview-line-short" style={`background: ${item.lineColor || itemColor}30`}></div>
                          </div>
                          <div class="preview-dot" style={`background: ${item.dotColor || itemColor}`}></div>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
            
            <!-- Duplicated group for seamless looping -->
            <div class="marquee-group marquee-left" aria-hidden="true">
              {finalPortfolioItems.map((item: any) => {
                const itemColor = item.bgColor || item.color || '#007cf0';
                return (
                  <div class="marquee-card">
                    <div class="portfolio-preview" style={`background: linear-gradient(135deg, ${itemColor}20 0%, ${itemColor}40 100%); border-bottom: 3px solid ${itemColor}`}>
                      {item.image ? (
                        <img src={urlFor(item.image).url()} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : item.imageUrl ? (
                        <img src={item.imageUrl} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : (
                        <div class="preview-inner">
                          <div class="preview-label text-caption-mono">{item.category.toUpperCase()}</div>
                          <div class="preview-lines">
                            <div class="preview-line preview-line-wide" style={`background: ${item.lineColor || itemColor}60`}></div>
                            <div class="preview-line preview-line-med" style={`background: ${item.lineColor || itemColor}40`}></div>
                            <div class="preview-line preview-line-short" style={`background: ${item.lineColor || itemColor}30`}></div>
                          </div>
                          <div class="preview-dot" style={`background: ${item.dotColor || itemColor}`}></div>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Track 2: Move Right -->
          <div class="marquee-track">
            <div class="marquee-group marquee-right">
              {[...finalPortfolioItems].reverse().map((item: any) => {
                const itemColor = item.bgColor || item.color || '#007cf0';
                return (
                  <div class="marquee-card" id={`marquee-r-${item.id || item._id}`} title={`Click to view ${item.title}`}>
                    <div class="portfolio-preview" style={`background: linear-gradient(135deg, ${itemColor}20 0%, ${itemColor}40 100%); border-bottom: 3px solid ${itemColor}`}>
                      {item.image ? (
                        <img src={urlFor(item.image).url()} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : item.imageUrl ? (
                        <img src={item.imageUrl} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : (
                        <div class="preview-inner">
                          <div class="preview-label text-caption-mono">{item.category.toUpperCase()}</div>
                          <div class="preview-lines">
                            <div class="preview-line preview-line-wide" style={`background: ${item.lineColor || itemColor}60`}></div>
                            <div class="preview-line preview-line-med" style={`background: ${item.lineColor || itemColor}40`}></div>
                            <div class="preview-line preview-line-short" style={`background: ${item.lineColor || itemColor}30`}></div>
                          </div>
                          <div class="preview-dot" style={`background: ${item.dotColor || itemColor}`}></div>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
            
            <!-- Duplicated group for seamless looping -->
            <div class="marquee-group marquee-right" aria-hidden="true">
              {[...finalPortfolioItems].reverse().map((item: any) => {
                const itemColor = item.bgColor || item.color || '#007cf0';
                return (
                  <div class="marquee-card">
                    <div class="portfolio-preview" style={`background: linear-gradient(135deg, ${itemColor}20 0%, ${itemColor}40 100%); border-bottom: 3px solid ${itemColor}`}>
                      {item.image ? (
                        <img src={urlFor(item.image).url()} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : item.imageUrl ? (
                        <img src={item.imageUrl} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : (
                        <div class="preview-inner">
                          <div class="preview-label text-caption-mono">{item.category.toUpperCase()}</div>
                          <div class="preview-lines">
                            <div class="preview-line preview-line-wide" style={`background: ${item.lineColor || itemColor}60`}></div>
                            <div class="preview-line preview-line-med" style={`background: ${item.lineColor || itemColor}40`}></div>
                            <div class="preview-line preview-line-short" style={`background: ${item.lineColor || itemColor}30`}></div>
                          </div>
                          <div class="preview-dot" style={`background: ${item.dotColor || itemColor}`}></div>
                        </div>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </section>

      <!-- Filter Tabs -->
      <div class="filter-bar">
        <div class="container-page">
          <div class="filter-tabs" role="tablist">
            {[
              { value: "thumbnail", label: "Thumbnails" },
              { value: "video", label: "Video Editing" },
              { value: "social", label: "Social Media" },
              { value: "branding", label: "Branding" },
            ].map(tab => (
              <button
                class={`filter-tab ${tab.value === 'thumbnail' ? 'filter-tab-active' : ''}`}
                data-filter={tab.value}
                role="tab"
                id={`filter-${tab.value}`}
              >
                {tab.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Portfolio Grid -->
      <section class="portfolio-section">
        <div class="container-page">
          <div class="portfolio-grid" id="portfolio-grid">
            {finalPortfolioItems.map((item: any) => {
              const itemColor = item.bgColor || item.color || '#007cf0';
              return (
                <div 
                  class="portfolio-card" 
                  data-category={item.category} 
                  id={`portfolio-item-${item.id || item._id}`}
                  style={item.category === 'thumbnail' ? '' : 'display: none;'}
                >
                  {item.category === 'video' ? (
                    <div class="video-container" style={`border-bottom: 3px solid ${itemColor}`}>
                      {item.youtubeUrl ? (
                        <iframe
                          width="100%"
                          height="100%"
                          src={getYouTubeEmbedUrl(item.youtubeUrl)}
                          title={item.title}
                          frameborder="0"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                          allowfullscreen
                          style="width: 100%; height: 100%; aspect-ratio: 16/9;"
                        ></iframe>
                      ) : (
                        <div class="video-placeholder" style="display:flex;align-items:center;justify-content:center;height:100%;background:#111;color:#666;font-size:14px;">No YouTube URL provided</div>
                      )}
                    </div>
                  ) : (
                    <div class="portfolio-preview" style={`background: linear-gradient(135deg, ${itemColor}20 0%, ${itemColor}40 100%); border-bottom: 3px solid ${itemColor}`}>
                      {item.image ? (
                        <img src={urlFor(item.image).url()} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : item.imageUrl ? (
                        <img src={item.imageUrl} alt={item.title} style="width:100%;height:100%;object-fit:cover;" />
                      ) : (
                        <div class="preview-inner">
                          <div class="preview-label text-caption-mono">{item.category.toUpperCase()}</div>
                          <div class="preview-lines">
                            <div class="preview-line preview-line-wide" style={`background: ${item.lineColor || itemColor}60`}></div>
                            <div class="preview-line preview-line-med" style={`background: ${item.lineColor || itemColor}40`}></div>
                            <div class="preview-line preview-line-short" style={`background: ${item.lineColor || itemColor}30`}></div>
                          </div>
                          <div class="preview-dot" style={`background: ${item.dotColor || itemColor}`}></div>
                        </div>
                      )}
                    </div>
                  )}
                  <div class="portfolio-info">
                    <h3 class="portfolio-item-title">{item.title}</h3>
                    <p class="portfolio-item-client">{item.client}</p>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="portfolio-cta">
        <div class="container-page portfolio-cta-inner">
          <div>
            <h2>{ctaHeading}</h2>
            <p>{ctaBody}</p>
          </div>
          <div class="portfolio-cta-btns">
            <a href="https://wa.me/917488316199?text=Hi%2C%20I%20want%20to%20order%20a%20design" target="_blank" rel="noopener noreferrer" class="cta-primary" id="portfolio-order-cta">Order Now →</a>
            <a href="/pricing" class="cta-secondary">View Pricing</a>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<script>
  const tabs = document.querySelectorAll('.filter-tab');
  const cards = document.querySelectorAll('.portfolio-card') as NodeListOf<HTMLElement>;

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('filter-tab-active'));
      tab.classList.add('filter-tab-active');

      const filter = tab.getAttribute('data-filter');
      cards.forEach(card => {
        if (filter === 'all' || card.getAttribute('data-category') === filter) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });

  // Marquee interactions: click to filter and scroll to card
  const marqueeCards = document.querySelectorAll('.marquee-card');
  marqueeCards.forEach(card => {
    card.addEventListener('click', () => {
      const idAttr = card.id;
      if (!idAttr) return;
      const id = idAttr.replace('marquee-l-', '').replace('marquee-r-', '');
      const gridCard = document.getElementById(`portfolio-item-${id}`);
      if (gridCard) {
        // Find category and filter first
        const category = gridCard.getAttribute('data-category');
        const filterTab = document.getElementById(`filter-${category}`) as HTMLElement;
        if (filterTab) {
          filterTab.click();
        }
        // Scroll to card
        gridCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
        // Add highlight pulse
        gridCard.classList.add('highlight-pulse');
        setTimeout(() => gridCard.classList.remove('highlight-pulse'), 1500);
      }
    });
  });
</script>

<style>
  .portfolio-hero { background: var(--color-canvas); border-bottom: 1px solid var(--color-hairline); padding: 64px 24px 48px; }
  .eyebrow { color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 12px; }
  .portfolio-heading { font-size: clamp(36px, 5vw, 56px); font-weight: 600; letter-spacing: -2px; color: var(--color-ink); margin: 0 0 16px; }
  .portfolio-subheading { font-size: 18px; color: var(--color-body); line-height: 28px; margin: 0; max-width: 420px; }

  .filter-bar { background: var(--color-canvas); border-bottom: 1px solid var(--color-hairline); padding: 16px 24px; }
  .filter-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
  .filter-tab {
    display: inline-flex; align-items: center; height: 36px; padding: 0 16px;
    font-size: 14px; font-weight: 400; color: var(--color-body);
    background: var(--color-canvas); border: 1px solid var(--color-hairline);
    border-radius: var(--radius-pill-sm); cursor: pointer;
    font-family: var(--font-sans);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }
  .filter-tab:hover { background: var(--color-canvas-soft-2); color: var(--color-ink); border-color: var(--color-hairline-strong); }
  .filter-tab-active {
    background: var(--color-ink); color: var(--color-on-primary); border-color: var(--color-ink);
  }

  .portfolio-section { padding: 64px 24px; background: var(--color-canvas-soft); }
  .portfolio-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .portfolio-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .portfolio-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-card-lg); }
  .portfolio-preview {
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .video-container {
    width: 100%;
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
    background: #000;
  }
  .preview-inner {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 24px;
    gap: 10px;
  }
  .preview-label { color: var(--color-mute); font-size: 10px; }
  .preview-lines { display: flex; flex-direction: column; gap: 8px; width: 100%; }
  .preview-line { height: 8px; border-radius: 4px; }
  .preview-line-wide { width: 80%; }
  .preview-line-med { width: 55%; }
  .preview-line-short { width: 35%; }
  .preview-dot { width: 32px; height: 32px; border-radius: 50%; margin-top: 8px; opacity: 0.7; }
  .portfolio-info { padding: 16px 20px; }
  .portfolio-item-title { font-size: 15px; font-weight: 600; color: var(--color-ink); margin: 0 0 4px; }
  .portfolio-item-client { font-size: 13px; color: var(--color-mute); margin: 0; }

  .portfolio-cta {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: 64px 24px;
  }
  .portfolio-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 40px; flex-wrap: wrap; }
  .portfolio-cta h2 { font-size: 28px; font-weight: 600; letter-spacing: -1px; color: var(--color-ink); margin: 0 0 8px; }
  .portfolio-cta p { font-size: 16px; color: var(--color-body); margin: 0; }
  .portfolio-cta-btns { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }
  .cta-primary {
    display: inline-flex; align-items: center; height: 48px; padding: 0 24px;
    font-size: 16px; font-weight: 500; color: var(--color-on-primary); background: var(--color-ink);
    border-radius: var(--radius-pill); text-decoration: none; transition: opacity 0.15s;
  }
  .cta-primary:hover { opacity: 0.85; }
  .cta-secondary {
    display: inline-flex; align-items: center; height: 48px; padding: 0 24px;
    font-size: 16px; font-weight: 500; color: var(--color-ink);
    border: 1px solid var(--color-hairline); background: var(--color-canvas);
    border-radius: var(--radius-pill); text-decoration: none; transition: border-color 0.15s, background 0.15s;
  }
  .cta-secondary:hover { border-color: var(--color-hairline-strong); background: var(--color-canvas-soft-2); }

  /* Moving Marquee Showcase */
  .marquee-showcase {
    background: var(--color-canvas-soft);
    border-bottom: 1px solid var(--color-hairline);
    padding: 32px 0;
    overflow: hidden;
  }

  .marquee-container {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
  }

  .marquee-mask {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 10;
    background: linear-gradient(90deg, var(--color-canvas-soft) 0%, transparent 10%, transparent 90%, var(--color-canvas-soft) 100%);
  }

  .marquee-track {
    display: flex;
    overflow: visible;
    width: 100%;
  }

  .marquee-group {
    display: flex;
    gap: 20px;
    padding: 10px 10px; /* Room for hover scale */
    flex-shrink: 0;
    min-width: 100%;
    justify-content: space-around;
  }

  .marquee-left {
    animation: scroll-left 50s linear infinite;
  }

  .marquee-right {
    animation: scroll-right 50s linear infinite;
  }

  /* Pause marquee when hovering over the container */
  .marquee-container:hover .marquee-left,
  .marquee-container:hover .marquee-right {
    animation-play-state: paused;
  }

  .marquee-card {
    width: 280px;
    aspect-ratio: 16/9;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    box-shadow: var(--shadow-card);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease, border-color 0.4s ease;
    flex-shrink: 0;
    cursor: pointer;
  }

  .marquee-card:hover {
    transform: scale(1.06);
    box-shadow: var(--shadow-card-lg);
    border-color: var(--color-hairline-strong);
    z-index: 20;
  }

  .marquee-card .portfolio-preview {
    width: 100%;
    height: 100%;
    border-bottom: none !important; /* Remove bottom border inside marquee */
  }

  @keyframes scroll-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  @keyframes scroll-right {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(0);
    }
  }

  /* Pulse highlight for clicked card in grid */
  @keyframes pulse-highlight {
    0% { transform: translateY(0) scale(1); box-shadow: var(--shadow-card); }
    50% { transform: translateY(-8px) scale(1.03); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04); border-color: var(--color-ink); }
    100% { transform: translateY(0) scale(1); box-shadow: var(--shadow-card); }
  }
  .highlight-pulse {
    animation: pulse-highlight 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    z-index: 30;
  }

  @media (max-width: 900px) { .portfolio-grid { grid-template-columns: repeat(2, 1fr); } }
