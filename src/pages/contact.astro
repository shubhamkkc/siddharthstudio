---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { sanityClient } from "../lib/sanity";
import { contactPageQuery, siteConfigQuery } from "../lib/queries";
import { buildWhatsAppHref, getWhatsAppBaseHref } from "../lib/contact";

let cms: any = null;
let siteSettings: any = null;
try {
  cms = await sanityClient.fetch(contactPageQuery);
} catch (e) {
  console.warn("Sanity fetch failed:", e);
}

try {
  siteSettings = await sanityClient.fetch(siteConfigQuery);
} catch (e) {
  console.warn("Sanity site settings fetch failed:", e);
}

const fallbackEmail = siteSettings?.email ?? "info@growsquadz.in";
const whatsappBaseHref = getWhatsAppBaseHref(siteSettings);
const orderWhatsAppHref = buildWhatsAppHref(whatsappBaseHref, "Hi, I want to order a design");

const seoTitle = cms?.seoTitle ?? "Contact — GrowSquadz";
const seoDescription = cms?.seoDescription ?? "Get in touch with GrowSquadz. Order designs via WhatsApp, email us, or connect on social media. Based in Patna, Bihar, India.";
const heroHeading = cms?.heroHeading ?? "Let's work together.";
const heroSubheading = cms?.heroSubheading ?? "We typically respond within 1 hour on WhatsApp. Drop us a message and we'll get started.";

const baseChannels = cms?.channels ?? [
  {
    platform: "whatsapp",
    label: "WhatsApp (Fastest)",
    value: "+91 74883 16199",
    tag: "Avg. response: <1 hr",
    href: orderWhatsAppHref,
    iconBg: "#25D366",
    iconColor: "white",
    borderColor: "var(--color-hairline-strong)"
  },
  {
    platform: "email",
    label: "Email",
    value: fallbackEmail,
    tag: "Response within 24 hours",
    href: `mailto:${fallbackEmail}`,
    iconBg: "var(--color-canvas-soft-2)",
    iconColor: "var(--color-ink)",
    borderColor: "var(--color-hairline-strong)"
  },
  {
    platform: "telegram",
    label: "Telegram",
    value: "@kumarsiddharth",
    tag: "Join our creator community",
    href: "https://t.me/kumarsiddharth",
    iconBg: "#0088cc",
    iconColor: "white",
    borderColor: "var(--color-hairline-strong)"
  },
  {
    platform: "instagram",
    label: "Instagram",
    value: "@growsquadz.in",
    tag: "See our latest work",
    href: "https://www.instagram.com/growsquadz.in/",
    iconBg: "#E1306C",
    iconColor: "white",
    borderColor: "var(--color-hairline-strong)"
  }
];

const finalChannels = baseChannels.map((channel: any) => {
  if (channel?.platform === "email") {
    return {
      ...channel,
      value: fallbackEmail,
      href: `mailto:${fallbackEmail}`,
    };
  }

  return channel;
});

const finalBusinessDetails = cms?.businessDetails ?? [
  { label: "REGISTERED NAME", value: "GrowSquadz Ventures Private Limited" },
  { label: "ADDRESS", value: "Sumitra Nagar, Biharimills Colony, Patna City, Patna, Bihar 800008" },
  { label: "BUSINESS HOURS", value: "Monday – Saturday, 9 AM – 8 PM IST" },
  { label: "PAYMENT METHODS", value: "UPI, Bank Transfer, Razorpay" }
];

const quickOrderHeading = cms?.quickOrderHeading ?? "Ready to order?";
const quickOrderBody = cms?.quickOrderBody ?? "The fastest way to get started is via WhatsApp. We'll confirm your order within minutes.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="GrowSquadz" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Navbar />
    <main>
      <!-- Hero -->
      <div class="contact-hero">
        <div class="container-page">
          <p class="eyebrow text-caption-mono">CONTACT</p>
          <h1 class="contact-heading">{heroHeading}</h1>
          <p class="contact-subheading">{heroSubheading}</p>
        </div>
      </div>

      <!-- Contact Grid -->
      <section class="contact-section">
        <div class="container-page contact-grid">
          <!-- Contact Channels -->
          <div class="channels">
            <h2 class="channels-heading">Reach us on</h2>
            <div class="channels-list">
              {finalChannels.map((channel: any) => (
                <a href={channel.href} target={channel.platform === 'email' ? '' : '_blank'} rel={channel.platform === 'email' ? '' : 'noopener noreferrer'} class={`channel-card channel-${channel.platform}`}>
                  <div class={`channel-icon channel-icon-${channel.platform}`}>
                    {/* SVG Icons based on platform string */}
                    {channel.platform === 'whatsapp' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>}
                    {channel.platform === 'email' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>}
                    {channel.platform === 'telegram' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>}
                    {channel.platform === 'instagram' && <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>}
                  </div>
                  <div class="channel-info">
                    <span class="channel-label">{channel.label}</span>
                    <span class="channel-value">{channel.value}</span>
                    <span class="channel-tag">{channel.tag}</span>
                  </div>
                  <span class="channel-arrow">→</span>
                </a>
              ))}
            </div>
          </div>

          <!-- Business Info -->
          <div class="biz-info">
            <div class="biz-card">
              <h2 class="biz-heading">Business Info</h2>
              {finalBusinessDetails.map((detail: any) => (
                <div class="biz-detail">
                  <span class="biz-label text-caption-mono">{detail.label}</span>
                  <span class="biz-value">{detail.value}</span>
                </div>
              ))}
            </div>
            <div class="quick-order-card">
              <h3 class="quick-order-heading">{quickOrderHeading}</h3>
              <p>{quickOrderBody}</p>
              <a href={orderWhatsAppHref} target="_blank" rel="noopener noreferrer" class="quick-order-btn" id="contact-quick-order">
                Order via WhatsApp →
              </a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .contact-hero {
    background: var(--color-canvas);
    border-bottom: 1px solid var(--color-hairline);
    padding: 64px 24px 48px;
  }
  .eyebrow { color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 12px; }
  .contact-heading { font-size: clamp(36px, 5vw, 56px); font-weight: 600; letter-spacing: -2px; color: var(--color-ink); margin: 0 0 16px; }
  .contact-subheading { font-size: 18px; color: var(--color-body); line-height: 28px; margin: 0; max-width: 480px; }

  .contact-section { padding: 72px 24px; background: var(--color-canvas-soft); }
  .contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }

  .channels-heading { font-size: 20px; font-weight: 600; color: var(--color-ink); margin: 0 0 24px; letter-spacing: -0.5px; }
  .channels-list { display: flex; flex-direction: column; gap: 12px; }
  .channel-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 20px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
    box-shadow: var(--shadow-card);
  }
  .channel-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-card-lg); border-color: var(--color-hairline-strong); }
  .channel-whatsapp { border-left: 3px solid #25d366; }
  .channel-icon {
    width: 52px; height: 52px;
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    background: #25d366;
    color: white;
  }
  .channel-icon-email { background: var(--color-canvas-soft-2); color: var(--color-ink); }
  .channel-icon-telegram { background: #2CA5E0; color: white; }
  .channel-icon-instagram { background: linear-gradient(135deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); color: white; }
  .channel-info { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .channel-label { font-size: 12px; font-weight: 600; color: var(--color-mute); text-transform: uppercase; letter-spacing: 0.06em; font-family: var(--font-mono); }
  .channel-value { font-size: 15px; font-weight: 500; color: var(--color-ink); }
  .channel-tag { font-size: 12px; color: var(--color-mute); }
  .channel-arrow { font-size: 20px; color: var(--color-mute); transition: transform 0.15s, color 0.15s; }
  .channel-card:hover .channel-arrow { transform: translateX(4px); color: var(--color-ink); }

  .biz-card {
    background: var(--color-canvas);
    border: 1px solid var(--color-hairline);
    border-radius: var(--radius-lg);
    padding: 32px;
    box-shadow: var(--shadow-card);
    margin-bottom: 16px;
  }
  .biz-heading { font-size: 18px; font-weight: 600; color: var(--color-ink); margin: 0 0 24px; }
  .biz-detail { padding: 16px 0; border-bottom: 1px solid var(--color-hairline); }
  .biz-detail:last-child { border-bottom: none; padding-bottom: 0; }
  .biz-label { display: block; font-size: 11px; color: var(--color-mute); letter-spacing: 0.06em; margin-bottom: 4px; }
  .biz-value { font-size: 15px; color: var(--color-ink); line-height: 22px; display: block; }
  .quick-order-card {
    background: #0a0a0c;
    border-radius: var(--radius-lg);
    padding: 28px;
    color: white;
  }
  .quick-order-heading { font-size: 18px; font-weight: 600; margin: 0 0 8px; }
  .quick-order-card p { font-size: 14px; color: #a1a1a1; line-height: 20px; margin: 0 0 20px; }
  .quick-order-btn {
    display: inline-flex; align-items: center; height: 44px; padding: 0 20px;
    font-size: 15px; font-weight: 500; color: #000; background: white;
    border-radius: var(--radius-pill); text-decoration: none; transition: opacity 0.15s;
  }
  .quick-order-btn:hover { opacity: 0.9; }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
  }
</style>
