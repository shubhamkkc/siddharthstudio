---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "India's premier creative design studio. Professional YouTube thumbnails, social media designs, and premium template packs at unbeatable prices.",
  image = "/logo.png",
  keywords = "YouTube thumbnails, Social media design, Video editing, Graphic design India, Content creator designs, Thumbnail designer, GrowSquadz",
  author = "GrowSquadz"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://growsquadz.in");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="GrowSquadz" />
    <link rel="manifest" href="/site.webmanifest" />
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      document.documentElement.setAttribute('data-theme', theme);
    </script>

    <!-- SEO -->
    <title>{title} | GrowSquadz</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | GrowSquadz`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | GrowSquadz`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts: Inter + JetBrains Mono from Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "GrowSquadz",
        "description": "India's premier creative design studio offering YouTube thumbnails, social media designs, and premium template packs.",
        "url": "https://www.growsquadz.in",
        "telephone": "+917488316199",
        "email": "info@growsquadz.in",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Sumitra Nagar, Biharimills Colony, Patna City",
          "addressLocality": "Patna",
          "addressRegion": "Bihar",
          "postalCode": "800008",
          "addressCountry": "IN"
        },
        "sameAs": [
          "https://youtube.com/@growsquadz",
          "https://www.instagram.com/growsquadz.in/"
        ]
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
