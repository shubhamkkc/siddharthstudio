---
import "../styles/global.css";
import { sanityClient } from "../lib/sanity";
import { siteConfigQuery } from "../lib/queries";

let siteSettings: any = null;
try {
  siteSettings = await sanityClient.fetch(siteConfigQuery);
} catch (e) {
  console.warn("Sanity fetch failed:", e);
}

const defaultFooterColumns = [
  {
    heading: "Services",
    links: [
      { label: "YouTube Thumbnails", href: "/services#thumbnails" },
      { label: "Social Media Posts", href: "/services#social-media" },
      { label: "Video Editing", href: "/services#video" },
      { label: "Logos & Branding", href: "/services#branding" },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "About Us", href: "/about" },
      { label: "Portfolio", href: "/portfolio" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    heading: "Legal",
    links: [
      { label: "Terms & Conditions", href: "/terms-conditions" },
      { label: "Disclaimer", href: "/disclaimer" },
      { label: "Privacy Policy", href: "/privacy" },
    ],
  },
];

const defaultSocialLinks = [
  {
    label: "YouTube",
    href: "https://youtube.com/@growsquadz",
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://www.instagram.com/growsquadz.in/",
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
  {
    label: "Telegram",
    href: "https://t.me/kumarsiddharth",
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
  },
  {
    label: "WhatsApp",
    href: "https://wa.me/917488316199",
    iconSvg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>`,
  },
];

const finalFooterColumns = siteSettings?.footerColumns ?? defaultFooterColumns;
const finalSocialLinks = siteSettings?.socialLinks ?? defaultSocialLinks;
const siteName = siteSettings?.siteName ?? "GrowSquadz";
const legalName = siteSettings?.legalName ?? "GrowSquadz Ventures Private Limited";
const footerEmail = siteSettings?.email ?? "info@growsquadz.in";
const footerPhone = siteSettings?.phone ?? "+91 74883 16199";
const footerAddress =
  siteSettings?.address ??
  "Sumitra Nagar, Biharimills Colony, Patna City, Patna, Bihar 800008";
const whatsappLink =
  siteSettings?.defaultOrderCtaHref ??
  siteSettings?.socialLinks?.find((l: any) => l.label?.toLowerCase() === "whatsapp")?.href ??
  "https://wa.me/917488316199?text=Hi%2C%20I%20want%20to%20order%20a%20design";
---

<footer class="footer-root">
  <!-- Top CTA Band -->
  <div class="footer-cta-band">
    <div class="container-page">
      <div class="footer-cta-inner">
        <div class="footer-cta-text">
          <p class="footer-cta-eyebrow text-caption-mono">GET STARTED TODAY</p>
          <h2 class="footer-cta-heading">Ready to elevate your content?</h2>
          <p class="footer-cta-body">
            Join thousands of creators who trust GrowSquadz for premium designs.
          </p>
        </div>
        <div class="footer-cta-actions">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary-lg"
          >
            Order Now →
          </a>
          <a href="/services" class="btn-secondary-lg">View Services</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer Nav -->
  <div class="footer-nav">
    <div class="container-page">
      <div class="footer-grid">
        <!-- Brand Column -->
        <div class="footer-brand">
          <a href="/" class="footer-logo" aria-label={siteName}>
            <img src="/logo-light.png" alt={`${siteName} Logo`} width="24" height="24" class="logo-image logo-light" />
            <img src="/logo-dark.png" alt={`${siteName} Logo`} width="24" height="24" class="logo-image logo-dark" />
            <span>{siteName}</span>
          </a>
          <p class="footer-brand-tagline">
            India's premier creative design studio. Professional designs for content creators and businesses.
          </p>
          <div class="footer-social">
          {finalSocialLinks.map((social: any) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="social-icon-btn"
              set:html={social.iconSvg || `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>`}
            />
          ))}
        </div>
          <p class="footer-contact-info">
            <a href={`mailto:${footerEmail}`}>{footerEmail}</a><br />
            <a href={`tel:${footerPhone.replace(/\s+/g, "")}`}>{footerPhone}</a>
          </p>
        </div>

        <!-- Link Columns -->
          {finalFooterColumns.map((col: any) => (
            <div class="footer-col">
              <p class="footer-col-heading text-caption-mono">{col.heading}</p>
              <ul role="list" class="footer-col-links">
                {col.links?.map((link: any) => (
                  <li>
                    <a href={link.href} class="footer-col-link">{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
      </div>

      <div class="footer-bottom">
        <p class="footer-bottom-text">
          © {new Date().getFullYear()} {legalName}. All rights reserved.
        </p>
        <p class="footer-bottom-text footer-address">
          {footerAddress}
        </p>
      </div>
    </div>
  </div>
</footer>

<!-- Floating WhatsApp CTA -->
<a
  href={whatsappLink}
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-float"
  aria-label="Chat on WhatsApp"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
  </svg>
</a>

<style>
  /* Footer CTA Band */
  .footer-cta-band {
    background-color: #0a0a0c;
    color: #fff;
    padding: 64px 24px;
  }
  .footer-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 48px;
    flex-wrap: wrap;
  }
  .footer-cta-eyebrow {
    color: #888;
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .footer-cta-heading {
    font-size: 32px;
    font-weight: 600;
    line-height: 40px;
    letter-spacing: -1.28px;
    color: white;
    margin: 0 0 12px;
  }
  .footer-cta-body {
    font-size: 16px;
    color: #a1a1a1;
    margin: 0;
    max-width: 420px;
  }
  .footer-cta-actions {
    display: flex;
    gap: 12px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .btn-primary-lg {
    display: inline-flex;
    align-items: center;
    height: 48px;
    padding: 0 24px;
    font-size: 16px;
    font-weight: 500;
    color: #000;
    background: white;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }
  .btn-primary-lg:hover { opacity: 0.9; }

  .btn-secondary-lg {
    display: inline-flex;
    align-items: center;
    height: 48px;
    padding: 0 24px;
    font-size: 16px;
    font-weight: 500;
    color: white;
    background: transparent;
    border: 1px solid #333;
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: border-color 0.15s ease, background-color 0.15s ease;
    white-space: nowrap;
  }
  .btn-secondary-lg:hover { border-color: #555; background: rgba(255,255,255,0.05); }

  /* Footer Nav */
  .footer-nav {
    background-color: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
    padding: 64px 24px 32px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  /* Brand Col */
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--color-ink);
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .logo-dark { display: none; }
  :root[data-theme="dark"] .logo-light { display: none; }
  :root[data-theme="dark"] .logo-dark { display: block; }
  .footer-brand-tagline {
    font-size: 14px;
    color: var(--color-body);
    line-height: 20px;
    margin: 0 0 20px;
    max-width: 280px;
  }
  .footer-social {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
  }
  .social-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-hairline);
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
  }
  .social-icon-btn:hover {
    color: var(--color-ink);
    border-color: var(--color-hairline-strong);
    background-color: var(--color-canvas-soft-2);
  }
  .footer-contact-info {
    font-size: 13px;
    color: var(--color-mute);
    line-height: 20px;
    margin: 0;
  }
  .footer-contact-info a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-contact-info a:hover { color: var(--color-ink); }

  /* Link Columns */
  .footer-col-heading {
    color: var(--color-mute);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 16px;
  }
  .footer-col-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-col-link {
    font-size: 14px;
    color: var(--color-body);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-col-link:hover { color: var(--color-ink); }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid var(--color-hairline);
    padding-top: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .footer-bottom-text {
    font-size: 12px;
    color: var(--color-mute);
    margin: 0;
  }
  .footer-address { text-align: right; }

  /* Floating WhatsApp */
  .whatsapp-float {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    background: #25d366;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.4);
    z-index: 100;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .whatsapp-float:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.5);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 40px; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-cta-inner { flex-direction: column; align-items: flex-start; gap: 32px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .footer-address { text-align: left; }
  }
</style>
